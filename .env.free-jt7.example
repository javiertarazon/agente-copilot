# Free JT7 gateway env template
# Completa solo si no quieres depender del perfil del IDE

TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# IDE/modelo resuelto por defecto: vscode/copilot-default

# ── Búsqueda en internet (opcional) ──────────────────────────────────────────
# Tavily  → https://app.tavily.com        (1.000 búsquedas/mes gratis)
TAVILY_API_KEY=tvly-

# Firecrawl → https://firecrawl.dev       (500 créditos/mes gratis, scraping)
FIRECRAWL_API_KEY=fc-

# Exa     → https://exa.ai               (1.000 búsquedas/mes gratis)
EXA_API_KEY=

# Sin ninguna key: usa fetch_webpage(url) o DuckDuckGo Instant (sin límite)
# https://api.duckduckgo.com/?q=TU+CONSULTA&format=json&no_html=1
